@{
    ViewData["Title"] = "Página no encontrada";
    Layout = null;  // Página standalone
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=1280" />
    <title>404 — Página no encontrada | SCA</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;900&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Outfit', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #FFFDE7 0%, #FFF8E1 50%, #FFFBF0 100%);
            position: relative;
            overflow: hidden;
        }

        body::before, body::after {
            content: '';
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            pointer-events: none;
        }
        body::before {
            width: 420px; height: 420px;
            background: rgba(255, 193, 7, 0.18);
            top: -100px; left: -80px;
        }
        body::after {
            width: 300px; height: 300px;
            background: rgba(255, 255, 255, 0.8);
            bottom: -60px; right: -60px;
        }

        .err-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 193, 7, 0.2);
            border-radius: 24px;
            padding: 52px 48px;
            text-align: center;
            max-width: 520px;
            width: 90%;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.06);
            position: relative;
            z-index: 1;
        }

        .err-icon {
            width: 88px;
            height: 88px;
            border-radius: 50%;
            background: rgba(255, 193, 7, 0.12);
            color: #B8860B;
            font-size: 2.4rem;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
        }

        .err-code {
            font-size: 5rem;
            font-weight: 900;
            background: linear-gradient(135deg, #FFC107, #FFD54F);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1;
            margin-bottom: 8px;
            letter-spacing: -2px;
        }

        .err-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #1A1A1A;
            margin-bottom: 12px;
        }

        .err-desc {
            font-size: 0.95rem;
            color: #888;
            font-weight: 500;
            line-height: 1.6;
            margin-bottom: 36px;
        }

        .err-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .err-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            border-radius: 14px;
            background: linear-gradient(135deg, #FFC107, #FFD54F);
            color: #1A1A1A;
            font-family: inherit;
            font-size: 0.95rem;
            font-weight: 700;
            text-decoration: none;
            border: none;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(255, 193, 7, 0.3);
            transition: 0.25s;
        }

        .err-btn:hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }

        .err-btn-sec {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(10px);
            border: 1.5px solid rgba(255, 193, 7, 0.3);
            color: #B8860B;
            box-shadow: none;
        }

        .err-btn-sec:hover {
            border-color: #FFC107;
            background: rgba(255, 193, 7, 0.06);
        }
    </style>
</head>
<body>
    <div class="err-card">
        <div class="err-icon"><i class="bi bi-compass"></i></div>
        <div class="err-code">404</div>
        <h1 class="err-title">Página no encontrada</h1>
        <p class="err-desc">
            La página que buscás no existe o fue movida.<br />
            Verificá la URL o volvé al inicio.
        </p>

        <div class="err-actions">
            <a href="/" class="err-btn">
                <i class="bi bi-house-fill"></i> Ir al inicio
            </a>
            <a href="javascript:history.back()" class="err-btn err-btn-sec">
                <i class="bi bi-arrow-left"></i> Volver
            </a>
        </div>
    </div>
</body>
</html>

@using SCA_MVC.Helpers
@if (TempData[MensajesUI.KEY_TITULO] != null || TempData[MensajesUI.KEY_CONTENIDO] != null)
{
    <div data-toast-message="@(TempData[MensajesUI.KEY_CONTENIDO] ?? "")"
         data-toast-title="@(TempData[MensajesUI.KEY_TITULO] ?? "")"
         data-toast-type="@(TempData[MensajesUI.KEY_TIPO] ?? "info")"
         style="display: none;"></div>
}

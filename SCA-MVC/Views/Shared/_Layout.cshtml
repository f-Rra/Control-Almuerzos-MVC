<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=1920, initial-scale=1.0, shrink-to-fit=yes" />
    <title>@ViewData["Title"] - SCA</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.2/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="shader"><div class="orb o1"></div><div class="orb o2"></div></div>

    <aside class="side">
        <div class="side-line">
            <div class="side-brand">
                <img src="~/images/logo.png" alt="SCA" />
                <h1>Control de Almuerzos</h1>
            </div>
        </div>
        <div class="side-nav">
            @{
                var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
            }
            <nav>
                @if (User.IsInRole("Admin"))
                {
                    <!-- Nav exclusiva del Administrador -->
                    <a asp-controller="Admin" asp-action="Index" class="mi @(controller == "Admin" ? "active" : "")" data-tip="Inicio">
                        <div class="bar"></div>
                        <div class="ico"><img src="~/images/home.png" /></div>
                        <span class="lbl">INICIO</span>
                    </a>
                    <a asp-controller="Empresa" asp-action="Index" class="mi @(controller == "Empresa" ? "active" : "")" data-tip="Empresas">
                        <div class="bar"></div>
                        <div class="ico ico-bi"><i class="bi bi-building"></i></div>
                        <span class="lbl">EMPRESAS</span>
                    </a>
                    <a asp-controller="Empleado" asp-action="Index" class="mi @(controller == "Empleado" ? "active" : "")" data-tip="Empleados">
                        <div class="bar"></div>
                        <div class="ico ico-bi"><i class="bi bi-people"></i></div>
                        <span class="lbl">EMPLEADOS</span>
                    </a>
                    <a asp-controller="Estadistica" asp-action="Index" class="mi @(controller == "Estadistica" ? "active" : "")" data-tip="Estadísticas">
                        <div class="bar"></div>
                        <div class="ico"><img src="~/images/estadisticas.png" /></div>
                        <span class="lbl">ESTADÍSTICAS</span>
                    </a>
                }
                else
                {
                    <!-- Nav operacional para usuarios regulares -->
                    <a asp-controller="Home" asp-action="Index" class="mi @(controller == "Home" ? "active" : "")" data-tip="Inicio">
                        <div class="bar"></div>
                        <div class="ico"><img src="~/images/home.png" /></div>
                        <span class="lbl">INICIO</span>
                    </a>
                    <a asp-controller="Servicio" asp-action="Index" class="mi @(controller == "Servicio" ? "active" : "")" data-tip="Servicios">
                        <div class="bar"></div>
                        <div class="ico"><img src="~/images/servicio.png" /></div>
                        <span class="lbl">SERVICIOS</span>
                    </a>
                    <a asp-controller="Registro" asp-action="Index" class="mi @(controller == "Registro" ? "active" : "")" data-tip="Registro Manual">
                        <div class="bar"></div>
                        <div class="ico"><img src="~/images/registro.png" /></div>
                        <span class="lbl">REGISTRO MANUAL</span>
                    </a>
                    <a asp-controller="Reporte" asp-action="Index" class="mi @(controller == "Reporte" ? "active" : "")" data-tip="Reportes">
                        <div class="bar"></div>
                        <div class="ico"><img src="~/images/Reporte.png" /></div>
                        <span class="lbl">REPORTES</span>
                    </a>
                    <a asp-controller="Estadistica" asp-action="Index" class="mi @(controller == "Estadistica" ? "active" : "")" data-tip="Estadísticas">
                        <div class="bar"></div>
                        <div class="ico"><img src="~/images/estadisticas.png" /></div>
                        <span class="lbl">ESTADÍSTICAS</span>
                    </a>
                }
            </nav>
        </div>
    </aside>

    <div class="right-panel">
        <nav class="topbar">
            <div class="user-area">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var nombreUsuario = User.FindFirst("NombreUsuario")?.Value ?? User.Identity.Name ?? "usuario";
                    <div class="pill">
                        <div class="avatar"><i class="bi bi-person-circle"></i></div>
                        <span class="uname">@nombreUsuario</span>
                    </div>
                    <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="logout" title="Cerrar sesión">
                            <i class="bi bi-power"></i>
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="pill">
                        <div class="avatar"><i class="bi bi-person"></i></div>
                        <span class="uname">Iniciar Sesión</span>
                    </a>
                }
            </div>
        </nav>

        <main class="content">
            @RenderBody()
        </main>

        <footer class="foot">
            <p>&lt;/&gt; SISTEMA CONTROL DE ALMUERZOS &mdash; 2026</p>
        </footer>
    </div>

    <!-- Toast Container -->
    <div class="sca-toast-container" id="sca-toast-container"></div>

    <partial name="_Notificaciones" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@model SCA_MVC.ViewModels.EstadisticasViewModel
@{
    ViewData["Title"] = "Estadísticas";
}

<div class="est-wrap">

<!-- ═══ FILA SUPERIOR — KPIs (3 columnas) ═══ -->
<div class="est-grid-top">

    <!-- ── Empleados ── -->
    <div class="panel est-card">
        <div class="est-card-head">
            <div class="est-card-ico empl"><i class="bi bi-people-fill"></i></div>
            <span class="est-card-title">Empleados</span>
        </div>
        <div class="est-card-body">
            <partial name="_KpiCard" model="@((Icono: "bi-people",       IcoColor: "",         Label: "Total Registrados", Valor: Model.TotalEmpleados.ToString()))" />
            <partial name="_KpiCard" model="@((Icono: "bi-person-check", IcoColor: "activo",   Label: "Activos",           Valor: Model.EmpleadosActivos.ToString()))" />
            <partial name="_KpiCard" model="@((Icono: "bi-person-x",     IcoColor: "inactivo", Label: "Inactivos",         Valor: Model.EmpleadosInactivos.ToString()))" />
        </div>
    </div>

    <!-- ── Empresas ── -->
    <div class="panel est-card">
        <div class="est-card-head">
            <div class="est-card-ico empresa"><i class="bi bi-building"></i></div>
            <span class="est-card-title">Empresas</span>
        </div>
        <div class="est-card-body">
            <partial name="_KpiCard" model="@((Icono: "bi-building-check", IcoColor: "empresa",  Label: "Total Activas",       Valor: Model.TotalEmpresasActivas.ToString()))" />
            <partial name="_KpiCard" model="@((Icono: "bi-diagram-3",      IcoColor: "",         Label: "Con Empleados",      Valor: Model.EmpresasConEmpleados.ToString()))" />
            <partial name="_KpiCard" model="@((Icono: "bi-calculator",     IcoColor: "promedio", Label: "Promedio (Empleados)", Valor: Model.PromedioEmpleados.ToString("F1")))" />
        </div>
    </div>

    <!-- ── Servicios ── -->
    <div class="panel est-card">
        <div class="est-card-head">
            <div class="est-card-ico servicio"><i class="bi bi-calendar-check"></i></div>
            <span class="est-card-title">Servicios</span>
        </div>
        <div class="est-card-body">
            <partial name="_KpiCard" model="@((Icono: "bi-calendar-event", IcoColor: "servicio", Label: "Este Mes",      Valor: Model.ServiciosEsteMes.ToString()))" />
            <partial name="_KpiCard" model="@((Icono: "bi-calendar-range", IcoColor: "",          Label: "Total del Año", Valor: Model.ServiciosEsteAnio.ToString()))" />
            <partial name="_KpiCard" model="@((Icono: "bi-graph-up",       IcoColor: "promedio",  Label: "Promedio / Día", Valor: Model.PromedioPorDia.ToString()))" />
        </div>
    </div>

</div>

<!-- ═══ FILA INFERIOR (2 columnas) ═══ -->
<div class="est-grid-bottom">

    <!-- ── Asistencias y Tendencias — placeholder hasta tener SP ── -->
    <div class="panel est-card est-card-wide">
        <div class="est-card-head">
            <div class="est-card-ico asist"><i class="bi bi-clipboard-data"></i></div>
            <span class="est-card-title">Asistencias y Tendencias</span>
            <span class="est-card-badge">Mes Actual</span>
        </div>
        <div class="est-card-body est-body-grid">
            <partial name="_KpiCard" model="@((Icono: "bi-clipboard-check", IcoColor: "asist",    Label: "Servicios Realizados",        Valor: Model.ServiciosEsteMes.ToString()))" />
            <partial name="_KpiCard" model="@((Icono: "bi-person-badge",    IcoColor: "empl",     Label: "Empleados Activos",           Valor: Model.EmpleadosActivos.ToString()))" />
            <partial name="_KpiCard" model="@((Icono: "bi-building",        IcoColor: "empresa",  Label: "Empresas Participantes",       Valor: Model.EmpresasConEmpleados.ToString()))" />
            <partial name="_KpiCard" model="@((Icono: "bi-graph-up-arrow",  IcoColor: "promedio", Label: "Promedio Empleados / Empresa", Valor: Model.PromedioEmpleados.ToString("F1")))" />
        </div>
    </div>

    <!-- ── Top Empresas ── -->
    <div class="panel est-card">
        <div class="est-card-head">
            <div class="est-card-ico top"><i class="bi bi-trophy"></i></div>
            <span class="est-card-title">Top Empresas</span>
            <span class="est-card-badge">Mes Actual</span>
        </div>
        <div class="est-card-body est-top-list">
            @if (Model.TopEmpresas.Any())
            {
                int maxAsis = Model.TopEmpresas.Max(e => e.TotalAsistencias);
                if (maxAsis == 0) maxAsis = 1;
                foreach (var e in Model.TopEmpresas)
                {
                    var barWidth = (int)((double)e.TotalAsistencias / maxAsis * 100);
                    <div class="est-top-item">
                        <span class="est-top-rank">@e.Ranking</span>
                        <div class="est-top-info">
                            <div class="est-top-head-row">
                                <span class="est-top-name">@e.NombreEmpresa</span>
                                <span class="est-top-pct">@e.Porcentaje.ToString("F1")%</span>
                            </div>
                            <div class="est-top-bar">
                                <div class="est-top-fill" style="width:@barWidth%"></div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="padding:16px; color:#999; text-align:center">
                    <i class="bi bi-inbox" style="font-size:1.5rem"></i>
                    <p>Sin datos este mes.</p>
                </div>
            }
        </div>
    </div>

</div>

</div>

@model SCA_MVC.ViewModels.EstadisticasViewModel
@{
    ViewData["Title"] = "Estadísticas";
}

<div class="est-wrap">

<!-- ═══ FILA SUPERIOR — KPIs (3 columnas) ═══ -->
<div class="est-grid-top">

    <!-- ── Empleados ── -->
    <div class="panel est-card">
        <div class="est-card-head">
            <div class="est-card-ico empl"><i class="bi bi-people-fill"></i></div>
            <span class="est-card-title">Empleados</span>
        </div>
        <div class="est-card-body">
            <div class="est-kpi">
                <div class="est-kpi-ico"><i class="bi bi-people"></i></div>
                <div class="est-kpi-info">
                    <span class="est-kpi-label">Total Registrados</span>
                    <span class="est-kpi-value">@Model.TotalEmpleados</span>
                </div>
            </div>
            <div class="est-kpi">
                <div class="est-kpi-ico activo"><i class="bi bi-person-check"></i></div>
                <div class="est-kpi-info">
                    <span class="est-kpi-label">Activos</span>
                    <span class="est-kpi-value activo">@Model.EmpleadosActivos</span>
                </div>
            </div>
            <div class="est-kpi">
                <div class="est-kpi-ico inactivo"><i class="bi bi-person-x"></i></div>
                <div class="est-kpi-info">
                    <span class="est-kpi-label">Inactivos</span>
                    <span class="est-kpi-value inactivo">@Model.EmpleadosInactivos</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Empresas ── -->
    <div class="panel est-card">
        <div class="est-card-head">
            <div class="est-card-ico empresa"><i class="bi bi-building"></i></div>
            <span class="est-card-title">Empresas</span>
        </div>
        <div class="est-card-body">
            <div class="est-kpi">
                <div class="est-kpi-ico empresa"><i class="bi bi-building-check"></i></div>
                <div class="est-kpi-info">
                    <span class="est-kpi-label">Total Activas</span>
                    <span class="est-kpi-value">@Model.TotalEmpresasActivas</span>
                </div>
            </div>
            <div class="est-kpi">
                <div class="est-kpi-ico"><i class="bi bi-diagram-3"></i></div>
                <div class="est-kpi-info">
                    <span class="est-kpi-label">Con Empleados</span>
                    <span class="est-kpi-value">@Model.EmpresasConEmpleados</span>
                </div>
            </div>
            <div class="est-kpi">
                <div class="est-kpi-ico promedio"><i class="bi bi-calculator"></i></div>
                <div class="est-kpi-info">
                    <span class="est-kpi-label">Promedio (Empleados)</span>
                    <span class="est-kpi-value promedio">@Model.PromedioEmpleados.ToString("F1")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Servicios ── -->
    <div class="panel est-card">
        <div class="est-card-head">
            <div class="est-card-ico servicio"><i class="bi bi-calendar-check"></i></div>
            <span class="est-card-title">Servicios</span>
        </div>
        <div class="est-card-body">
            <div class="est-kpi">
                <div class="est-kpi-ico servicio"><i class="bi bi-calendar-event"></i></div>
                <div class="est-kpi-info">
                    <span class="est-kpi-label">Este Mes</span>
                    <span class="est-kpi-value">@Model.ServiciosEsteMes</span>
                </div>
            </div>
            <div class="est-kpi">
                <div class="est-kpi-ico"><i class="bi bi-calendar-range"></i></div>
                <div class="est-kpi-info">
                    <span class="est-kpi-label">Total del Año</span>
                    <span class="est-kpi-value">@Model.ServiciosEsteAnio</span>
                </div>
            </div>
            <div class="est-kpi">
                <div class="est-kpi-ico promedio"><i class="bi bi-graph-up"></i></div>
                <div class="est-kpi-info">
                    <span class="est-kpi-label">Promedio / Día</span>
                    <span class="est-kpi-value promedio">@Model.PromedioPorDia</span>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ═══ FILA INFERIOR (2 columnas) ═══ -->
<div class="est-grid-bottom">

    <!-- ── Asistencias y Tendencias — placeholder hasta tener SP ── -->
    <div class="panel est-card est-card-wide">
        <div class="est-card-head">
            <div class="est-card-ico asist"><i class="bi bi-clipboard-data"></i></div>
            <span class="est-card-title">Asistencias y Tendencias</span>
            <span class="est-card-badge">Mes Actual</span>
        </div>
        <div class="est-card-body est-body-grid">
            <div class="est-kpi">
                <div class="est-kpi-ico asist"><i class="bi bi-clipboard-check"></i></div>
                <div class="est-kpi-info">
                    <span class="est-kpi-label">Servicios Realizados</span>
                    <span class="est-kpi-value">@Model.ServiciosEsteMes</span>
                </div>
            </div>
            <div class="est-kpi">
                <div class="est-kpi-ico empl"><i class="bi bi-person-badge"></i></div>
                <div class="est-kpi-info">
                    <span class="est-kpi-label">Empleados Activos</span>
                    <span class="est-kpi-value">@Model.EmpleadosActivos</span>
                </div>
            </div>
            <div class="est-kpi">
                <div class="est-kpi-ico empresa"><i class="bi bi-building"></i></div>
                <div class="est-kpi-info">
                    <span class="est-kpi-label">Empresas Participantes</span>
                    <span class="est-kpi-value">@Model.EmpresasConEmpleados</span>
                </div>
            </div>
            <div class="est-kpi">
                <div class="est-kpi-ico promedio"><i class="bi bi-graph-up-arrow"></i></div>
                <div class="est-kpi-info">
                    <span class="est-kpi-label">Promedio Empleados / Empresa</span>
                    <span class="est-kpi-value promedio">@Model.PromedioEmpleados.ToString("F1")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Top Empresas ── -->
    <div class="panel est-card">
        <div class="est-card-head">
            <div class="est-card-ico top"><i class="bi bi-trophy"></i></div>
            <span class="est-card-title">Top Empresas</span>
            <span class="est-card-badge">Mes Actual</span>
        </div>
        <div class="est-card-body est-top-list">
            @if (Model.TopEmpresas.Any())
            {
                int maxAsis = Model.TopEmpresas.Max(e => e.TotalAsistencias);
                if (maxAsis == 0) maxAsis = 1;
                foreach (var e in Model.TopEmpresas)
                {
                    var barWidth = (int)((double)e.TotalAsistencias / maxAsis * 100);
                    <div class="est-top-item">
                        <span class="est-top-rank">@e.Ranking</span>
                        <div class="est-top-info">
                            <div class="est-top-head-row">
                                <span class="est-top-name">@e.NombreEmpresa</span>
                                <span class="est-top-pct">@e.Porcentaje.ToString("F1")%</span>
                            </div>
                            <div class="est-top-bar">
                                <div class="est-top-fill" style="width:@barWidth%"></div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="padding:16px; color:#999; text-align:center">
                    <i class="bi bi-inbox" style="font-size:1.5rem"></i>
                    <p>Sin datos este mes.</p>
                </div>
            }
        </div>
    </div>

</div>

</div>
